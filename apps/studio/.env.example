SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional. Use a lowercase snake_case prefix ending in "_" to isolate branch data
# inside the same Supabase project, for example:
# TRACE_TABLE_PREFIX=branch_build_v0_1_local_replay_
TRACE_TABLE_PREFIX=

# Optional. When set, POST /api/traces and DELETE /api/runs/:runId require this
# key via an "x-api-key" (or "Authorization: Bearer") header. Leave empty for
# local development. Generate one with: openssl rand -hex 24
AGENT_BREACH_INGEST_KEY=
